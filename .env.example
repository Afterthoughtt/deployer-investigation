# Shared (audit scripts + monitor daemon)
HELIUS_API_KEY=

# Audit scripts only
NANSEN_API_KEY=
ARKAN_API_KEY=

# Audit guardrails — Arkham intel labels are scarce; row endpoints are capped.
# ARKHAM_DATAPOINT_RESERVE=2000
# ARKHAM_LABEL_LOOKUP_RUN_BUDGET=0
# ARKHAM_ALLOW_BATCH_INTEL=0
# ARKHAM_ROW_LIMIT_MAX=25
# ARKHAM_ROW_CREDIT_RUN_BUDGET=200
# ARKHAM_ALLOW_UNBOUNDED_TIME=0
# ARKHAM_ALLOW_ROW_PAGINATION=0

# Optional for scripts that sample Arkham /transfers, e.g. deep-dive.ts.
# ARKHAM_TRANSFER_LIMIT=25
# ARKHAM_TRANSFER_TIME_LAST=24h
# ARKHAM_TRANSFER_TIME_GTE=2026-04-24T00:00:00Z
# ARKHAM_TRANSFER_TIME_LTE=2026-04-25T00:00:00Z

# Monitor daemon only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitor daemon — optional overrides
# DB_PATH=./data/l11.db         # relative paths resolve from monitor/
# LOG_LEVEL=info                # trace | debug | info | warn | error | fatal
